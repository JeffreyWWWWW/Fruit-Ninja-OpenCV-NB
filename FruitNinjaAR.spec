from PyInstaller.utils.hooks import collect_all

datas = [('assets', 'assets'), ('background', 'background'), ('cursor', 'cursor'), ('fonts', 'fonts'), ('fruits', 'fruits'), ('sounds', 'sounds'), ('music', 'music'), ('hand_tracking.py', '.')]
binaries = []
hiddenimports = []
